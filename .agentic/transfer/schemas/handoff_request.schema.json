{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vfi64.github.io/agentic-project-kit/schemas/handoff_request.schema.json",
  "title": "agentic-project-kit local-to-LLM handoff request",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "message_kind",
    "assignment_kind",
    "created_at_utc",
    "result_status",
    "final_signal",
    "chat_reply",
    "next_action",
    "repo",
    "llm_assignment",
    "transfer_rules_text",
    "transfer_protocol_machine",
    "required_sources",
    "missing_sources",
    "command_inventory",
    "blockers"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "const": "local_to_llm_last_result"
    },
    "message_kind": {
      "const": "handoff_request"
    },
    "assignment_kind": {
      "const": "successor_chat_prompt"
    },
    "result_status": {
      "enum": [
        "PASS",
        "BLOCK"
      ]
    },
    "final_signal": {
      "enum": [
        "d",
        "f"
      ]
    },
    "repo": {
      "type": "object",
      "required": [
        "full_name",
        "local_path",
        "branch",
        "head",
        "upstream",
        "upstream_head",
        "head_matches_upstream",
        "dirty_status",
        "worktree_clean"
      ]
    },
    "llm_assignment": {
      "type": "object",
      "required": [
        "task",
        "language",
        "must_do",
        "must_not_do",
        "response_contract"
      ]
    },
    "transfer_protocol_machine": {
      "type": "object",
      "required": [
        "priority_order",
        "canonical_files",
        "command_policy"
      ]
    },
    "required_sources": {
      "type": "array"
    },
    "missing_sources": {
      "type": "array"
    },
    "command_inventory": {
      "type": "object"
    },
    "blockers": {
      "type": "array"
    }
  }
}

#!/usr/bin/env bash
set -u

mkdir -p tmp/agent-evidence docs/reports
STAMP="$(date +%Y%m%d-%H%M%S)"
OUT="tmp/agent-evidence/workflow-output-${STAMP}.md"

{
  echo "# Workflow output"
  echo
  echo "Date: $(date "+%Y-%m-%d %H:%M:%S")"
  echo "Branch: $(git branch --show-current)"
  echo
  echo "## Git status"
  git status --short
  echo
  echo "## Git log"
  git log --oneline -10

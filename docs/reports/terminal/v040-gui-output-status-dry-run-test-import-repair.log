from agentic_project_kit.gui_dry_run import render_gui_dry_run


def test_gui_dry_run_exposes_output_status_panel_block():
    output = render_gui_dry_run()
    assert "output_status_panel_begin" in output
    assert "GUI OUTPUT STATUS PANEL" in output
    assert "status=clean" in output
    assert "branch=dry-run" in output
    assert "terminal_log=NONE" in output
    assert "evidence_state=not_required" in output
    assert "latest_output_begin" in output
    assert "GUI dry-run initialized without executing an action." in output
    assert "latest_output_end" in output
    assert "summary_begin" in output
    assert "No command summary exists in dry-run mode." in output
    assert "summary_end" in output
    assert "output_status_panel_end" in output


def test_gui_dry_run_output_status_panel_precedes_layout_rendering():
    output = render_gui_dry_run()
    assert output.index("output_status_panel_begin") < output.index("layout_plan_begin")


  git branch --show-current || STATUS=1
  git status --short || STATUS=1
  if [ "$STATUS" -eq 0 ]; then
    printf '\n### RESULT: PASS ###\n'
    exit 0
  fi
  printf '\n### RESULT: FAIL ###\n'
  exit 1
fi

 if [ "${1:-}" = "go" ]; then
  shift
  BRANCH="$(git branch --show-current 2>/dev/null)"
  DIRTY="$(git status --short 2>/dev/null)"
  if [ "$BRANCH" != "main" ] && [ -n "$DIRTY" ] && grep -q "git_pull_ff_only" .agentic/current_work.yaml 2>/dev/null; then
    printf '
### NS GO GUARD ###
'
    printf 'Refusing governed workflow go on a dirty feature branch because current_work includes git_pull_ff_only.
'
    printf 'Use ./ns dev for local feature gates, or clean the branch before ./ns go.
'
    printf '
### RESULT: FAIL ###
'
    exit 2
  fi
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow go "$@"
  fi
  exec agentic-kit workflow go "$@"
fi

        "runner": "./.venv/bin/agentic-kit transfer remote-next",
        "user_visible": true
      },
      "python_payload_lane": {
        "direct_user_execution": "forbidden_except_recovery",
        "file": ".agentic/transfer/inbox/next_command.py.txt",
        "role": "pure_python_payload",
        "runner": "./.venv/bin/python",
        "user_visible": false
      }
    },
    "transfer_priorities": [
      "remote_repo_backed_work_first",
      "canonical_one_command_remote_next_second",
      "canonical_transfer_files_second",
      "copy_paste_only_fallback"
    ]
  },
  "schema_version": 1
}

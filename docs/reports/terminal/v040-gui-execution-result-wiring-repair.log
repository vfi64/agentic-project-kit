    66	def run_gui_dry_run(project_root: Path | None = None) -> GuiDryRunResult:
    67	    root = Path.cwd() if project_root is None else project_root
    68	    tkinter_available = _module_available("tkinter")
    69	    action_registry_available = _module_available("agentic_project_kit.action_registry")
    70	    action_specs_available = _module_available("agentic_project_kit.action_specs")
    71	    mode_guard_available = _mode_guard_available(root)
    72	    shell_adapters_absent = _shell_adapters_absent(root)
    73	    presenter = build_no_window_presenter_result(list_actions())
    74	    ok = all((
    75	        action_registry_available,
    76	        action_specs_available,
    77	        mode_guard_available,
    78	        shell_adapters_absent,
    79	        presenter.ok,
    80	    ))
    81	    message = "GUI dry-run passed without opening a window." if ok else "GUI dry-run failed."
    82	    return GuiDryRunResult(
    83	        ok=ok,
    84	        tkinter_available=tkinter_available,
    85	        action_registry_available=action_registry_available,
    86	        action_specs_available=action_specs_available,
    87	        presenter_available=presenter.ok,
    88	        presenter_action_count=presenter.action_count,
    89	        presenter_preview=presenter.rendered,

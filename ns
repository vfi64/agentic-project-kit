#!/usr/bin/env sh
set -eu
SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
cd "$SCRIPT_DIR"
if [ "${1:-}" = "cockpit" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit cockpit status "$@"
  fi
  exec agentic-kit cockpit status "$@"
fi
if [ "${1:-}" = "actions" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit cockpit actions "$@"
  fi
  exec agentic-kit cockpit actions "$@"
fi
if [ "${1:-}" = "select" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit cockpit select "$@"
  fi
  exec agentic-kit cockpit select "$@"
fi
if [ "${1:-}" = "cockpit-run" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit cockpit run "$@"
  fi
  exec agentic-kit cockpit run "$@"
fi
if [ "${1:-}" = "state" ] || [ "${1:-}" = "status" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow state "$@"
  fi
  exec agentic-kit workflow state "$@"
fi
if [ "${1:-}" = "list" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow list "$@"
  fi
  exec agentic-kit workflow list "$@"
fi
if [ "${1:-}" = "show" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow show "$@"
  fi
  exec agentic-kit workflow show "$@"
fi
if [ "${1:-}" = "run" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow run "$@"
  fi
  exec agentic-kit workflow run "$@"
fi
if [ "${1:-}" = "release-prep" ]; then
  shift
  exec tools/ns_release_prep.sh "$@"
fi
if [ "${1:-}" = "release-gate" ]; then
  shift
  exec tools/ns_release_gate.sh "$@"
fi
if [ "${1:-}" = "release-publish" ]; then
  shift
  exec tools/ns_release_publish.sh "$@"
fi
if [ "${1:-}" = "release-verify" ]; then
  shift
  exec tools/ns_release_verify.sh "$@"
fi
if [ "${1:-}" = "commit-guard" ]; then
  shift
  exec tools/ns_commit_pr_guard.sh "$@"
fi

if [ "${1:-}" = "dev" ]; then
  shift
  STATUS=0
  printf '\n### NS DEV LOCAL FEATURE GATE ###\n'
  printf 'Safety: local feature gate; no git pull, push, merge, tag, release, or branch deletion.\n'
  printf '\n### BRANCH / STATUS ###\n'
  git branch --show-current || STATUS=1
  git status --short || STATUS=1
  printf '\n### PYTEST ###\n'
  .venv/bin/python -m pytest -q "$@" || STATUS=1
  printf '\n### RUFF ###\n'
  .venv/bin/ruff check . || STATUS=1
  printf '\n### CHECK DOCS ###\n'
  PYTHONPATH=src .venv/bin/python -m agentic_project_kit.cli check-docs || STATUS=1
  printf '\n### DOCTOR ###\n'
  PYTHONPATH=src .venv/bin/python -m agentic_project_kit.cli doctor || STATUS=1
  printf '\n### PR HYGIENE ###\n'
  PYTHONPATH=src .venv/bin/python -m agentic_project_kit.cli pr-hygiene || STATUS=1
  printf '\n### FINAL STATE ###\n'
  git branch --show-current || STATUS=1
  git status --short || STATUS=1
  if [ "$STATUS" -eq 0 ]; then
    printf '\n### RESULT: PASS ###\n'
    exit 0
  fi
  printf '\n### RESULT: FAIL ###\n'
  exit 1
fi

 if [ "${1:-}" = "go" ]; then
  shift
  BRANCH="$(git branch --show-current 2>/dev/null)"
  DIRTY="$(git status --short 2>/dev/null)"
  if [ "$BRANCH" != "main" ] && [ -n "$DIRTY" ] && grep -q "git_pull_ff_only" .agentic/current_work.yaml 2>/dev/null; then
    printf '
### NS GO GUARD ###
'
    printf 'Refusing governed workflow go on a dirty feature branch because current_work includes git_pull_ff_only.
'
    printf 'Use ./ns dev for local feature gates, or clean the branch before ./ns go.
'
    printf '
### RESULT: FAIL ###
'
    exit 2
  fi
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow go "$@"
  fi
  exec agentic-kit workflow go "$@"
fi
if [ "${1:-}" = "up" ]; then
  shift
  exec tools/ns_up_pr_completion.sh "$@"
fi

if [ "${1:-}" = "upload" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow upload "$@"
  fi
  exec agentic-kit workflow upload "$@"
fi

if [ "${1:-}" = "fail" ]; then
  shift
  if [ -x ".venv/bin/agentic-kit" ]; then
    exec .venv/bin/agentic-kit workflow fail-report "$@"
  fi
  exec agentic-kit workflow fail-report "$@"
fi

if [ -x ".venv/bin/python" ]; then
  exec .venv/bin/python tools/next-step.py "$@"
fi
exec python3 tools/next-step.py "$@"

# no-copy workflow shortcuts: ./ns dev, ./ns go, ./ns up

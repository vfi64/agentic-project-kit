#!/usr/bin/env sh

resolve_python() {
  if [ -x ".venv/bin/python" ]; then
    printf "%s
" ".venv/bin/python"
  elif [ -x ".venv/bin/python3" ]; then
    printf "%s
" ".venv/bin/python3"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  elif command -v python >/dev/null 2>&1; then
    command -v python
  else
    return 1
  fi
}

PY="$(resolve_python || true)"

if [ "${1:-}" = "pr-status" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.next_turn_pr_status "$@"
  exit $?
fi

if [ "${1:-}" = "next-turn-evidence" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.next_turn_evidence "$@"
  exit $?
fi

if [ "${1:-}" = "next-turn-result" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.next_turn_result "$@"
  exit $?
fi

if [ "${1:-}" = "next-turn" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.next_turn_status next-turn "$@"
  exit $?
fi
if [ "${1:-}" = "last-result" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.next_turn_status last-result "$@"
  exit $?
fi

if [ "${1:-}" = "pr-create-or-skip" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.pr_create_or_skip "$@"
  exit $?
fi
if [ -z "$PY" ]; then
  printf "%s
" "ERROR: no usable Python interpreter found. Expected .venv/bin/python, .venv/bin/python3, python3, or python."
  printf "%s
" "### RESULT: FAIL ###"
  return 127 2>/dev/null || exit 127
fi





if [ "${1:-}" = "dev-local-feature-gate" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.local_feature_gate "$@"
  exit $?
fi

if [ "${1:-}" = "governance-check" ]; then
  PYTHONPATH=src "$PY" -m agentic_project_kit.cli governance check
  exit $?
fi

if [ "${1:-}" = "state-freshness-check" ]; then
  PYTHONPATH=src "$PY" -m agentic_project_kit.cli state freshness-check
  exit $?
fi

if [ "${1:-}" = "gui" ]; then
  shift
  PYTHONPATH=src "$PY" -m agentic_project_kit.gui_dry_run "$@"
  exit $?
fi

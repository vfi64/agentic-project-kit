#!/usr/bin/env sh

resolve_python() {
  if [ -x ".venv/bin/python" ]; then
    printf "%s
" ".venv/bin/python"
  elif [ -x ".venv/bin/python3" ]; then
    printf "%s
" ".venv/bin/python3"
  elif command -v python3 >/dev/null 2>&1; then
    command -v python3
  elif command -v python >/dev/null 2>&1; then
    command -v python
  else
    return 1
  fi
}

PY="$(resolve_python || true)"
if [ -z "$PY" ]; then
  printf "%s
" "ERROR: no usable Python interpreter found. Expected .venv/bin/python, .venv/bin/python3, python3, or python."
  printf "%s
" "### RESULT: FAIL ###"
  return 127 2>/dev/null || exit 127
fi





